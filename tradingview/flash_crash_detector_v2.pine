// This source code is subject to the terms of the Mozilla Public License 2.0
// © trading_bot / Flash Crash Detector v2 — ROC early-warning + intrabar alert
//@version=6
indicator(title="Flash Crash Detector v2", shorttitle="FC DET v2", overlay=true, max_labels_count=500)

// ─────────────────────────────────────────────
// INPUTS — DETECTION (velocity-first, matches strategy v2)
// ─────────────────────────────────────────────

i_roc_len   = input.int(3,     "ROC Lookback (K bars)",  minval=1, group="Crash Detection",
              tooltip="Cumulative % drop measured over the last K bars.")
i_roc_thr   = input.float(-4.0,"ROC Threshold % (drop over K)", maxval=0.0, step=0.5, group="Crash Detection")

i_vol_len   = input.int(20,    "Volume SMA Lookback (M)", minval=1, group="Crash Detection")
i_vol_mult  = input.float(1.7, "Volume Multiplier (Y)",   minval=0.1, step=0.1, group="Crash Detection")

i_atr_len   = input.int(14,    "ATR Lookback (N)",        minval=1, group="Crash Detection")
i_atr_mult  = input.float(2.5, "ATR Body Multiplier (X)", minval=0.1, step=0.1, group="Crash Detection")

i_intrabar  = input.bool(true, "Fire intrabar (earliest, may repaint)", group="Alerts",
              tooltip="ON = alert can fire mid-bar for earliest warning. OFF = wait for bar close (no repaint).")

// ─────────────────────────────────────────────
// DETECTION
// ─────────────────────────────────────────────

roc         = (close - close[i_roc_len]) / close[i_roc_len] * 100
vol_sma     = ta.sma(volume, i_vol_len)
vol_ok      = volume > vol_sma * i_vol_mult
atr         = ta.atr(i_atr_len)
body        = open - close
bearish     = close < open

roc_trig    = roc < i_roc_thr and vol_ok            // fast bleed / cascade
candle_trig = body > atr * i_atr_mult and vol_ok    // single violent candle
crash       = bearish and (roc_trig or candle_trig)

// ─────────────────────────────────────────────
// VISUALS
// ─────────────────────────────────────────────

bgcolor(crash ? color.new(color.red, 85) : na, title="Crash Background")

if crash
    label.new(bar_index, high,
     text      = "⚠️ FLASH CRASH\nROC " + str.tostring(math.round(roc, 1)) + "%" +
                 "\nVol ×" + str.tostring(math.round(volume / vol_sma, 1)),
     yloc      = yloc.abovebar,
     color     = color.new(color.red, 10),
     textcolor = color.white,
     style     = label.style_label_down,
     size      = size.normal)

plotshape(crash, "Crash Signal", shape.triangledown, location.abovebar,
          color.red, size=size.small, text="CRASH")

// ─────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────

// Classic alertcondition — register from the Alerts dialog (app/popup/email/webhook)
alertcondition(crash,
    title   = "Flash Crash Detected",
    message = "⚠️ FLASH CRASH | {{ticker}} | TF: {{interval}} | Close: {{close}} | ROC drop | Time: {{time}}")

// Inline alert() — intrabar by default for the earliest possible warning
if crash
    alert(
     "⚠️ FLASH CRASH DETECTED\n"                                                       +
     "Ticker : " + syminfo.tickerid + "\n"                                              +
     "Time   : " + str.format_time(time, "yyyy-MM-dd HH:mm", syminfo.timezone) + "\n"  +
     "Close  : " + str.tostring(close) + "\n"                                           +
     "ROC    : " + str.tostring(math.round(roc, 2)) + "% over " + str.tostring(i_roc_len) + " bars\n" +
     "Volume : " + str.tostring(volume) + " (×" + str.tostring(math.round(volume / vol_sma, 1)) + " SMA)",
     i_intrabar ? alert.freq_once_per_bar : alert.freq_once_per_bar_close)
