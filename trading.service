[Unit]
Description=Gunicorn instance to serve my Flask app
After=network.target

[Service]
User=root
Group=www-data
WorkingDirectory=/root/webhook_lisener
Environment="PATH=/root/venv/bin"
ExecStart=/root/venv/bin/gunicorn -w 4 -b 127.0.0.1:5000 webhook_listener:app

[Install]
WantedBy=multi-user.target
